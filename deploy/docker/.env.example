# Docker 将容器端口发布到宿主机的地址。默认仅绑定本机，避免暴露无鉴权 /mcp。
PUBLISH_HOST=127.0.0.1

# 容器内服务监听地址。Docker 场景通常保持 0.0.0.0。
HOST=0.0.0.0

# 对外发布和容器内监听使用的端口。
PORT=18799

# 是否启用 /docs 和 /docs-json。生产部署默认保持 false。
ENABLE_API_DOCS=false

# 容器内运行时数据目录。
DATA_DIR=/app/runtime-data

# 容器内 SQLite 数据库文件路径。
SQLITE_PATH=/app/runtime-data/wallet.sqlite

# 容器内首次启动凭证提示文件路径。
OWNER_NOTICE_PATH=/app/runtime-data/owner-credential.txt

# JWT 访问令牌有效期，单位为秒。
OWNER_JWT_TTL=3600

# 本地管理面的 JWT 签名密钥。生产部署必须显式填写高熵随机值。
OWNER_JWT_SECRET=

# CKB 链配置模式。preset 使用内置主网/测试网配置，custom 使用挂载进容器的 JSON 文件。
CKB_CHAIN_MODE=preset

# 当 CKB_CHAIN_MODE=preset 时生效，可选值为 testnet 或 mainnet。
CKB_CHAIN_PRESET=testnet

# 当 CKB_CHAIN_MODE=custom 时取消注释，并指定容器内的 CKB 链配置文件路径。
# CKB_CHAIN_CONFIG_PATH=/app/chain-config/ckb.custom.json

# EVM 链配置模式。preset 使用内置主网/测试网配置，custom 使用挂载进容器的 JSON 文件。
EVM_CHAIN_MODE=preset

# 当 EVM_CHAIN_MODE=preset 时生效，可选值为 testnet 或 mainnet。
EVM_CHAIN_PRESET=testnet

# 当 EVM_CHAIN_MODE=custom 时取消注释，并指定容器内的 EVM 链配置文件路径。
# EVM_CHAIN_CONFIG_PATH=/app/chain-config/evm.custom.json

# 是否允许直接通过环境变量明文提供 KEK。默认应保持 false。
ALLOW_PLAINTEXT_KEK_ENV=false

# 服务日志级别。
LOG_LEVEL=info
