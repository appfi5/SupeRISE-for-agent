# Node 运行环境。开发时使用 development，生产部署时使用 production。
NODE_ENV=development

# 是否启用 /docs 和 /docs-json。只有显式设置为 true 才会开启。
ENABLE_API_DOCS=true

# 服务监听地址。开发模式默认只监听本机回环地址。
HOST=127.0.0.1

# 服务监听端口。
PORT=18799

# 运行时数据目录。数据库、首次启动凭证文件等默认会写入这里。
DATA_DIR=./data

# SQLite 数据库文件路径。
SQLITE_PATH=./data/wallet.sqlite

# 首次启动时写出的本地管理凭证提示文件路径。
OWNER_NOTICE_PATH=./data/owner-credential.txt

# JWT 访问令牌有效期，单位为秒。
OWNER_JWT_TTL=3600

# 本地管理面的 JWT 签名密钥。开发环境可使用固定示例值，生产环境必须改成高熵随机值。
OWNER_JWT_SECRET=superise-dev-owner-jwt-secret

# 转账结算轮询间隔，单位毫秒。
TRANSFER_SETTLEMENT_INTERVAL_MS=15000

# RESERVED 状态的广播前超时时间，单位毫秒。
TRANSFER_RESERVED_TIMEOUT_MS=30000

# SUBMITTED 状态的链上确认超时时间，单位毫秒。
TRANSFER_SUBMITTED_TIMEOUT_MS=1800000

# CKB 链配置模式。preset 使用内置主网/测试网配置，custom 使用外部 JSON 文件。
CKB_CHAIN_MODE=preset

# 当 CKB_CHAIN_MODE=preset 时生效，可选值为 testnet 或 mainnet。
CKB_CHAIN_PRESET=testnet

# 当 CKB_CHAIN_MODE=custom 时取消注释，并指定自定义 CKB 链配置文件路径。
# CKB_CHAIN_CONFIG_PATH=./apps/wallet-server/config/ckb.custom.example.json

# EVM 链配置模式。preset 使用内置主网/测试网配置，custom 使用外部 JSON 文件。
EVM_CHAIN_MODE=preset

# 当 EVM_CHAIN_MODE=preset 时生效，可选值为 testnet 或 mainnet。
EVM_CHAIN_PRESET=testnet

# 当 EVM_CHAIN_MODE=custom 时取消注释，并指定自定义 EVM 链配置文件路径。
# EVM_CHAIN_CONFIG_PATH=./apps/wallet-server/config/evm.custom.example.json

# 是否允许直接通过环境变量明文提供 KEK。默认应保持 false，仅用于受控调试场景。
ALLOW_PLAINTEXT_KEK_ENV=false
