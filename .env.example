# SupeRISELocalServer Docker Environment Variables
#
# Copy this file to .env and edit as needed:
#   cp .env.example .env
#
# Values set here are picked up by docker-compose.yml.
# Never commit the .env file – it may contain secrets.

# ---------------------------------------------------------------------------
# Network – which port the host exposes
# ---------------------------------------------------------------------------
# HOST_PORT=18799

# ---------------------------------------------------------------------------
# CKB node settings
# ---------------------------------------------------------------------------
# CKB_NETWORK=0          # 0 = mainnet, 1 = testnet
# CKB_NODE_URL=https://mainnet.ckb.dev

# ---------------------------------------------------------------------------
# Debug mode
#   true  → auto-generates a CKB key pair on first startup (useful for dev)
#   false → requires an existing key already stored in the database
# ---------------------------------------------------------------------------
# IS_DEBUG=false
