{
  "name": "@superise/infrastructure",
  "version": "0.3.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup src/index.ts --format esm,cjs --dts --clean",
    "dev": "tsup src/index.ts --format esm,cjs --dts --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@superise/app-contracts": "workspace:*",
    "@superise/application": "workspace:*",
    "@superise/domain": "workspace:*",
    "@superise/shared": "workspace:*",
    "better-sqlite3": "^12.4.1",
    "jsonwebtoken": "^9.0.2",
    "kysely": "^0.28.8",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/jsonwebtoken": "^9.0.10"
  }
}
