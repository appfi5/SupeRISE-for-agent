FROM node:22-alpine AS runtime
WORKDIR /app

RUN corepack enable

COPY package.json pnpm-workspace.yaml ./
COPY apps ./apps
COPY packages ./packages

RUN pnpm install --frozen-lockfile=false --prod=false

ENV PORT=3000
ENV HOST=0.0.0.0
ENV DB_PATH=/data/wallet.sqlite

VOLUME ["/data"]
EXPOSE 3000

CMD ["pnpm", "--filter", "@superise/wallet-api", "start"]
